# Copy this file to .env and fill in your SMTP credentials
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu-app-password

# For other providers (Brevo, Mailgun, etc.) use their SMTP settings
